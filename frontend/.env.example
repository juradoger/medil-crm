# Variables de entorno del frontend — copiar a .env y completar con los valores reales
# Obtené estos valores desde tu panel de InsForge (insforge.com > proyecto > settings)
VITE_INSFORGE_API_URL=https://tu-appkey.us-east.insforge.app
VITE_INSFORGE_API_KEY=ik_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL del backend Express desplegado en Render (sin barra final).
# Si falta, el frontend usa http://localhost:3001 (solo sirve en desarrollo).
VITE_BACKEND_URL=https://medil-backend.onrender.com

# Tablas requeridas en InsForge (ya creadas via CLI):
# patients | appointments | medical_records | reminders
